<UserControl x:Class="FondationBB_ARDIET_BUJOR.Windows.UCListeAnimaux"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="640" d:DesignWidth="1280" Background="#FFFFFF">

    <Grid>
        <!-- Même structure de lignes que UCListeClients -->
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Colonne gauche : Filtres + DataGrid -->
            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Zone de filtres harmonisée -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Filtres Textes -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Nom animal" FontWeight="SemiBold"/>
                            <TextBox x:Name="txtFiltreNom" Height="30" Margin="0,0,0,5" TextChanged="FiltreAnimal_Changed"/>
                            <TextBlock Text="Espèce animal" FontWeight="SemiBold"/>
                            <TextBox x:Name="txtFiltreEspece" Height="30" TextChanged="FiltreAnimal_Changed"/>
                        </StackPanel>

                        <!-- Filtres Sexe -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Mâle" Width="60" VerticalAlignment="Center"/>
                                <CheckBox x:Name="chkMale" Click="FiltreAnimal_Changed"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Femelle" Width="60" VerticalAlignment="Center"/>
                                <CheckBox x:Name="chkFemelle" Click="FiltreAnimal_Changed"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Filtres Statut -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Adopté" Width="80" VerticalAlignment="Center"/>
                                <CheckBox x:Name="chkAdopte" Click="FiltreAnimal_Changed"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Au refuge" Width="80" VerticalAlignment="Center"/>
                                <CheckBox x:Name="chkAuRefuge" Click="FiltreAnimal_Changed"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- DataGrid des Animaux -->
                <DataGrid Grid.Row="1" x:Name="dgAnimaux" ItemsSource="{Binding LesAnimaux}" AutoGenerateColumns="False" IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Image" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Viewbox Width="18" Height="18" Margin="5,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="Black" Data="M19,5V19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M14.14,11.86L11.14,15.66L9,13.08L6,17H18L14.14,11.86Z" />
                                        </Canvas>
                                    </Viewbox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="I-CAD" Binding="{Binding ICAD}" Width="*"/>
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                        <DataGridTextColumn Header="Espèce" Binding="{Binding Espece}" Width="*"/>
                        <DataGridTextColumn Header="Sexe" Binding="{Binding Sexe}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Colonne droite : Boutons + Fiche de l'animal -->
            <StackPanel Grid.Column="1">
                <!-- Boutons d'action alignés horizontalement à droite -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <Button x:Name="btnAjouter" ToolTip="Ajouter" FontFamily="Segoe MDL2 Assets" Content="&#xE109;" Width="40" Height="40" Margin="0,0,5,0" Click="BtnAjouter_Click"/>
                    <Button x:Name="btnEditer" ToolTip="Éditer" FontFamily="Segoe MDL2 Assets" Content="&#xE104;" Width="40" Height="40" Margin="0,0,5,0" Click="BtnEditer_Click"/>
                    <Button x:Name="btnSupprimer" ToolTip="Supprimer" FontFamily="Segoe MDL2 Assets" Content="&#xE74D;" Width="40" Height="40" Click="BtnSupprimer_Click"/>
                </StackPanel>

                <!-- Fiche détaillée -->
                <Border Background="#F9F9F9" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0" MaxHeight="450">
                        <StackPanel DataContext="{Binding SelectedItem, ElementName=dgAnimaux}">
                            <TextBlock Text="Fiche animal" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                    </Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Height" Value="28"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="IsReadOnly" Value="True"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                    </Style>
                                </Grid.Resources>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="I-CAD"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ICAD}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Nom"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Nom}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Espèce"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Espece}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Race"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Race}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Sexe"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Sexe}"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Âge"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Age}"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Poids"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Poids}"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Arrivée" TextWrapping="Wrap"/>
                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding DateArrivee, StringFormat={}{0:dd/MM/yyyy}}"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Soins reçus"/>
                                <TextBox Grid.Row="8" Grid.Column="1" Height="50" VerticalContentAlignment="Top" Padding="5,2" AcceptsReturn="True" Text="{Binding SoinsRecus}"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" Text="Annotations" TextWrapping="Wrap"/>
                                <TextBox Grid.Row="9" Grid.Column="1" Height="50" VerticalContentAlignment="Top" Padding="5,2" AcceptsReturn="True" Text="{Binding Annotations}"/>

                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Statut"/>
                                <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding Statut}"/>

                                <TextBlock Grid.Row="11" Grid.Column="0" Text="État de santé"/>
                                <TextBox Grid.Row="11" Grid.Column="1" Margin="0" Text="{Binding EtatSante}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>