<Window x:Class="FondationBB_ARDIET_BUJOR.Windows.ListeClients"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Liste des Clients" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen" Background="#FFFFFF">
    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#004A99">
            <Image Source="/Images/logo.png" Margin="20,10" Width="150" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                <Button x:Name="btnAnimaux" Content="Animaux" Style="{StaticResource HeaderButtonStyle}" Click="btnAnimaux_Click"/>
                <Button Content="Clients" Background="#003570" Style="{StaticResource HeaderButtonStyle}"/>
                <Button x:Name="btnAdoptions" Content="Adoptions" Style="{StaticResource HeaderButtonStyle}" Click="btnAdoptions_Click"/>
                <Button x:Name="btnDemandes" Content="Demandes" Style="{StaticResource HeaderButtonStyle}" Click="btnDemandes_Click"/>
                <Button x:Name="btnStatistiques" Content="Statistique" Style="{StaticResource HeaderButtonStyle}" Click="btnStatistiques_Click"/>
                <Button Content="Déconnexion" Background="#E60000" Margin="20,0,0,0" Style="{StaticResource HeaderButtonStyle}" Click="btnDeconnexion_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Nom client" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtFiltreNom" Height="30" Margin="0,0,0,5"/>
                    <TextBlock Text="Prénom client" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtFiltrePrenom" Height="30"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="dgClients" AutoGenerateColumns="False" IsReadOnly="True" 
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <Button FontFamily="Segoe MDL2 Assets" Content="&#xE109;" Width="40" Height="40" Margin="0,0,5,0"/>
                    <Button FontFamily="Segoe MDL2 Assets" Content="&#xE104;" Width="40" Height="40" Margin="0,0,5,0"/>
                    <Button FontFamily="Segoe MDL2 Assets" Content="&#xE74D;" Width="40" Height="40"/>
                </StackPanel>

                <Border Background="#F9F9F9" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20">
                    <StackPanel DataContext="{Binding SelectedItem, ElementName=dgClients}">
                        <TextBlock Text="Fiche client" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        <TextBlock Text="Nom"/>
                        <TextBox Text="{Binding Nom}" Margin="0,0,0,10"/>
                        <TextBlock Text="Prénom"/>
                        <TextBox Text="{Binding Prenom}" Margin="0,0,0,10"/>
                        <TextBlock Text="Adresse"/>
                        <TextBox Text="{Binding Adresse}" Margin="0,0,0,10"/>
                        <TextBlock Text="Téléphone"/>
                        <TextBox Text="{Binding Telephone}" Margin="0,0,0,10"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>