<Window x:Class="FondationBB_ARDIET_BUJOR.Windows.ListeAnimaux"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FondationBB_ARDIET_BUJOR.Windows"
        mc:Ignorable="d"
        Title="Liste des Animaux" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF">
    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#004A99" Height="80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Source="pack://application:,,,/Images/logo.png" Margin="20,10" Width="150"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                <Button Content="Statistique" Style="{StaticResource HeaderButtonStyle}"/>
                <Button Content="Animaux" Background="#003570" Style="{StaticResource HeaderButtonStyle}"/>
                <Button Content="Clients" Style="{StaticResource HeaderButtonStyle}"/>
                <Button Content="Adoptions" Style="{StaticResource HeaderButtonStyle}"/>
                <Button Content="Demandes" Style="{StaticResource HeaderButtonStyle}"/>
                <Button Content="Déconnexion" Background="#E60000" Margin="20,0,0,0" Style="{StaticResource HeaderButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

            </Grid>

            <Grid Grid.Row="1">
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="100,0,0,0" Width="50" >
                    <Button x:Name="btnAjouter" ToolTip="Ajouter" Margin="0,0,0,10" Click="BtnAjouter_Click" FontFamily="Segoe MDL2 Assets" Content="&#xE109;" Height="50" Width="50"/>
                    <Button x:Name="btnEditer" ToolTip="Éditer" Margin="0,0,0,10" Click="BtnEditer_Click" FontFamily="Segoe MDL2 Assets" Content="&#xE104;" Height="50" Width="50"/>
                    <Button x:Name="btnSupprimer" ToolTip="Supprimer" Click="BtnSupprimer_Click" FontFamily="Segoe MDL2 Assets" Content="&#xE74D;" Height="50" Width="50"/>
                </StackPanel>
                <StackPanel Grid.Column="0" Margin="0,0,30,0">
                    <TextBlock Text="Nom animal" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtFiltreNom" Height="35" Background="#F2F2F2" BorderBrush="#BDBDBD" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,10" TextChanged="FiltreAnimal_Changed"/>

                    <TextBlock Text="Espèce animal" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtFiltreEspece" Height="35" Background="#F2F2F2" BorderBrush="#BDBDBD" FontSize="14" VerticalContentAlignment="Center" TextChanged="FiltreAnimal_Changed"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Male" FontSize="15" FontWeight="SemiBold" Width="80" VerticalAlignment="Center"/>
                        <CheckBox x:Name="chkMale" Click="FiltreAnimal_Changed">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Femelle" FontSize="15" FontWeight="SemiBold" Width="80" VerticalAlignment="Center"/>
                        <CheckBox x:Name="chkFemelle" Click="FiltreAnimal_Changed">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Adopté" FontSize="15" FontWeight="SemiBold" Width="100" VerticalAlignment="Center"/>
                        <CheckBox x:Name="chkAdopte" Click="FiltreAnimal_Changed">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Au refuge" FontSize="15" FontWeight="SemiBold" Width="100" VerticalAlignment="Center"/>
                        <CheckBox x:Name="chkAuRefuge" Click="FiltreAnimal_Changed">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5.5*"/>
                    <ColumnDefinition Width="4.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F9F9F9" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,15,0" Padding="10">
                    <DataGrid x:Name="dgAnimaux" ItemsSource="{Binding LesAnimaux}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="None" Background="Transparent" BorderThickness="0" RowHeight="40" FontSize="14">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="15"/>
                                <Setter Property="Padding" Value="5,5,5,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border BorderBrush="#000000" BorderThickness="1" Margin="3,2" Background="Transparent" CornerRadius="2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Image" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Viewbox Width="18" Height="18">
                                            <Canvas Width="24" Height="24">
                                                <Path Fill="Black" Data="M19,5V19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M14.14,11.86L11.14,15.66L9,13.08L6,17H18L14.14,11.86Z" />
                                            </Canvas>
                                        </Viewbox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="I-CAD" Binding="{Binding ICAD}" Width="1.5*"/>
                            <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="1.5*"/>
                            <DataGridTextColumn Header="Espece" Binding="{Binding Espece}" Width="1.5*"/>
                            <DataGridTextColumn Header="Sexe" Binding="{Binding Sexe}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15,10,15,15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
                        <StackPanel DataContext="{Binding SelectedItem, ElementName=dgAnimaux}" Margin="0,0,5,0">

                            <TextBlock Text="Fiche animal" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                    </Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Height" Value="32"/>
                                        <Setter Property="Background" Value="#D9D9D9"/>
                                        <Setter Property="BorderBrush" Value="#000000"/>
                                        <Setter Property="BorderThickness" Value="1.2"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0,0,0"/>
                                        <Setter Property="IsReadOnly" Value="True"/>
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                    </Style>
                                </Grid.Resources>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="I-CAD"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ICAD}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Nom"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Nom}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Espece"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Espece}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Race"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Race}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Sexe"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Sexe}"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Âge"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Age}"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Poid"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Poids}"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Date d'arrivée" TextWrapping="Wrap"/>
                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding DateArrivee, StringFormat={}{0:dd/MM/yyyy}}"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Soins reçus"/>
                                <TextBox Grid.Row="8" Grid.Column="1" Height="55" VerticalContentAlignment="Top" Padding="8,4,0,0" AcceptsReturn="True" Text="{Binding SoinsRecus}"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" Text="Annotations" TextWrapping="Wrap" Margin="0,0,5,10"/>
                                <TextBox Grid.Row="9" Grid.Column="1" Height="55" VerticalContentAlignment="Top" Padding="8,4,0,0" AcceptsReturn="True" Text="{Binding Annotations}"/>

                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Statut"/>
                                <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding Statut}"/>

                                <TextBlock Grid.Row="11" Grid.Column="0" Text="État de santé"/>
                                <TextBox Grid.Row="11" Grid.Column="1" Margin="0" Text="{Binding EtatSante}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>