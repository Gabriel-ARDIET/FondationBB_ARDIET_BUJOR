<Window x:Class="FondationBB_ARDIET_BUJOR.Windows.Connexion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FondationBB_ARDIET_BUJOR.Windows"
        mc:Ignorable="d"
        Title="Connexion" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="600">

            <TextBlock Text="AUTHENTIFICATION" 
                       FontSize="36" 
                       FontWeight="Bold" 
                       Foreground="#003CA6" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,40"/>

            <Border Background="#F9F9F9" CornerRadius="30" Padding="50,40,50,40" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Nom d’utilisateur" FontSize="18" FontWeight="SemiBold" Foreground="#000000" Margin="0,0,0,8"/>
                    <TextBox x:Name="tbUserName" Height="50" Background="#F2F2F2" BorderBrush="#BDBDBD" BorderThickness="1" FontSize="16" VerticalContentAlignment="Center" Padding="10,0,10,0" Margin="0,0,0,30"/>
                    <TextBlock Text="Mot de passe" FontSize="18" FontWeight="SemiBold" Foreground="#000000" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="pbMDP" Height="50" Background="#F2F2F2" BorderBrush="#BDBDBD" BorderThickness="1" FontSize="16" VerticalContentAlignment="Center" Padding="10,0,10,0" Margin="0,0,0,40"/>
                    <Button x:Name="btnConnexion" Content="CONNEXION" Width="200" Height="50" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Click="btnConnexion_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#003CA6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#002D80"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>