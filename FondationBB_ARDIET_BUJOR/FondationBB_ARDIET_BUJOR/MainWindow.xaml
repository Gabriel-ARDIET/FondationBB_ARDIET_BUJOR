<Window x:Class="FondationBB_ARDIET_BUJOR.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fondation Brigitte Bardot" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen" Background="#FFFFFF">

    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="MenuHeader" Grid.Row="0" Background="#004A99" Height="80" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Images/logo.png" Margin="20,10" Width="150"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                <Button x:Name="btnAnimaux" Content="Animaux" Style="{StaticResource HeaderButtonStyle}" Click="btnMenu_Click"/>
                <Button x:Name="btnClients" Content="Clients" Style="{StaticResource HeaderButtonStyle}" Click="btnMenu_Click"/>
                <Button x:Name="btnAdoptions" Content="Adoptions" Style="{StaticResource HeaderButtonStyle}" Click="btnMenu_Click"/>
                <Button x:Name="btnDemandes" Content="Demandes" Style="{StaticResource HeaderButtonStyle}" Click="btnMenu_Click"/>
                <Button x:Name="btnStatistiques" Content="Statistiques" Style="{StaticResource HeaderButtonStyle}" Click="btnMenu_Click"/>
                <Button x:Name="btnDeconnexion" Content="Déconnexion" Background="#E60000" Margin="20,0,0,0" Style="{StaticResource HeaderButtonStyle}" Click="btnDeconnexion_Click"/>
            </StackPanel>
        </Grid>

        <ContentControl x:Name="ZoneContenu" Grid.Row="1" Margin="0"/>
    </Grid>
</Window>